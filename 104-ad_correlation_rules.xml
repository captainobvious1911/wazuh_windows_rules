<!--
  ad_correlation_rules.xml

  
    4740 lockout       100300  60103,60104 -> 60115
    4720 created       100304  60103       -> 60109
    4722 enabled       100306  60103       -> 60109
    4726 deleted       100305  60103       -> 60111
    4725 disabled      100307  60103       -> 60111
    4728 g-grp add     100310  60103       -> 60141
    4732 l-grp add     100311  60103       -> 60144
    4756 u-grp add     100312  60103       -> 60151
    4729 g-grp rem     100313  60103       -> 60142
    4733 l-grp rem     100314  60103       -> 60145
    4757 u-grp rem     100315  60103       -> 60152
    5136 ds-modified   100350  60103       -> 60229
    4719 audit policy  100351  60103       -> 60112
    1102 log cleared   100352  60103,60104 -> 60117   (CRITICAL: see note)

  GROUP-MEMBERSHIP NOTE (100310-100315): the default ruleset already
  has tier-0 SID-specific rules under 60141/60142/60144/60145/60151/60152
  (e.g. 60159 Domain Admins L12, 60154 Administrators L12, 60166 Schema
  Admins / 60167 Enterprise Admins L12). Those load first, so changes to
  privileged groups still alert via the default high-level rule, while
  generic L8-L10 rules fire for all OTHER (non-tier-0) groups. This
  is the intended, conflict-free split.

  NOT shadowed - left unchanged (no default rule matches the event ID):
    100302 (4724), 100303 (4723), 100320 (4672), 100321 (4670),
    100322 (4648), 100332 (4662 DCSync), 100340/100341/100343 (4688).
  Pure correlations unchanged: 100301, 100316, 100323, 100331, 100342.

-->
<group name="windows,ad_correlation,">

  <!-- ============================================================
       SECTION 1 — Account Management Events
       ============================================================ -->

  <!-- Account Lockout (4740 is audit-success on the DC; chained under 60115) -->
  <rule id="100300" level="10">
    <if_sid>60115</if_sid>
    <field name="win.system.eventID">^4740$</field>
    <options>no_full_log</options>
    <description>AD: Account lockout — $(win.eventdata.targetUserName) on $(win.system.computer)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failed,account_lockout,</group>
  </rule>

  <!-- Brute-force correlation: many lockouts in short window -->
  <rule id="100301" level="13" frequency="5" timeframe="120">
    <if_matched_sid>100300</if_matched_sid>
    <options>no_full_log</options>
    <description>AD: Multiple account lockouts detected — possible brute-force</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failed,brute_force,</group>
  </rule>

  <!-- Password Reset by Admin (no default rule for 4724 — unchanged) -->
  <rule id="100302" level="8">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4724$</field>
    <options>no_full_log</options>
    <description>AD: Password reset by admin — $(win.eventdata.targetUserName) reset by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,password_reset,</group>
  </rule>

  <!-- Password Change by User (no default rule for 4723 — unchanged) -->
  <rule id="100303" level="5">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4723$</field>
    <options>no_full_log</options>
    <description>AD: Password changed by user — $(win.eventdata.targetUserName)</description>
    <group>account_changed,password_change,</group>
  </rule>

  <!-- Account Created (default 60109 matches 4720/4722; chained under it) -->
  <rule id="100304" level="10">
    <if_sid>60109</if_sid>
    <field name="win.system.eventID">^4720$</field>
    <options>no_full_log</options>
    <description>AD: New user account created — $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1136.002</id>
    </mitre>
    <group>account_changed,account_created,</group>
  </rule>

  <!-- Account Deleted (default 60111 matches 4725/4726; chained under it) -->
  <rule id="100305" level="10">
    <if_sid>60111</if_sid>
    <field name="win.system.eventID">^4726$</field>
    <options>no_full_log</options>
    <description>AD: User account deleted — $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1531</id>
    </mitre>
    <group>account_changed,account_deleted,</group>
  </rule>

  <!-- Account Enabled (default 60109 matches 4720/4722; chained under it) -->
  <rule id="100306" level="8">
    <if_sid>60109</if_sid>
    <field name="win.system.eventID">^4722$</field>
    <options>no_full_log</options>
    <description>AD: User account enabled — $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,</group>
  </rule>

  <!-- Account Disabled (default 60111 matches 4725/4726; chained under it) -->
  <rule id="100307" level="8">
    <if_sid>60111</if_sid>
    <field name="win.system.eventID">^4725$</field>
    <options>no_full_log</options>
    <description>AD: User account disabled — $(win.eventdata.targetUserName)</description>
    <group>account_changed,</group>
  </rule>

  <!-- ============================================================
       SECTION 2 — Group Membership Changes
       Chained under the default per-scope member rules (60141 global,
       60144 local, 60151 universal add / 60142,60145,60152 remove).
       Tier-0 SID rules under those parents load first and still win.
       ============================================================ -->

  <!-- Member added to Global Security Group -->
  <rule id="100310" level="10">
    <if_sid>60141</if_sid>
    <field name="win.system.eventID">^4728$</field>
    <options>no_full_log</options>
    <description>AD: Member added to global security group $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName) — member: $(win.eventdata.memberName)</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,group_changed,</group>
  </rule>

  <!-- Member added to Local Security Group -->
  <rule id="100311" level="10">
    <if_sid>60144</if_sid>
    <field name="win.system.eventID">^4732$</field>
    <options>no_full_log</options>
    <description>AD: Member added to local security group $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName) — member: $(win.eventdata.memberName)</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,group_changed,</group>
  </rule>

  <!-- Member added to Universal Security Group -->
  <rule id="100312" level="10">
    <if_sid>60151</if_sid>
    <field name="win.system.eventID">^4756$</field>
    <options>no_full_log</options>
    <description>AD: Member added to universal security group $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName) — member: $(win.eventdata.memberName)</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,group_changed,</group>
  </rule>

  <!-- Member removed from Global Security Group -->
  <rule id="100313" level="8">
    <if_sid>60142</if_sid>
    <field name="win.system.eventID">^4729$</field>
    <options>no_full_log</options>
    <description>AD: Member removed from global security group $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName) — member: $(win.eventdata.memberName)</description>
    <group>account_changed,group_changed,</group>
  </rule>

  <!-- Member removed from Local Security Group -->
  <rule id="100314" level="8">
    <if_sid>60145</if_sid>
    <field name="win.system.eventID">^4733$</field>
    <options>no_full_log</options>
    <description>AD: Member removed from local security group $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName) — member: $(win.eventdata.memberName)</description>
    <group>account_changed,group_changed,</group>
  </rule>

  <!-- Member removed from Universal Security Group -->
  <rule id="100315" level="8">
    <if_sid>60152</if_sid>
    <field name="win.system.eventID">^4757$</field>
    <options>no_full_log</options>
    <description>AD: Member removed from universal security group $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName) — member: $(win.eventdata.memberName)</description>
    <group>account_changed,group_changed,</group>
  </rule>

  <!-- Rapid group membership changes — possible privilege escalation -->
  <rule id="100316" level="14" frequency="4" timeframe="120">
    <if_matched_sid>100310</if_matched_sid>
    <same_field>win.eventdata.subjectUserName</same_field>
    <options>no_full_log</options>
    <description>AD: Rapid group membership additions by same admin — possible privilege escalation</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,group_changed,privilege_escalation,</group>
  </rule>

  <!-- ============================================================
       SECTION 3 — Privilege Use & Special Logon
       No default rule matches 4672 or 4670 — left under 60103.
       ============================================================ -->

  <!-- Special Privileges Assigned to New Logon -->
  <rule id="100320" level="6">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4672$</field>
    <options>no_full_log</options>
    <description>AD: Special privileges assigned to logon — $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>privilege_escalation,special_logon,</group>
  </rule>

  <!-- Permissions on Object Changed -->
  <rule id="100321" level="8">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4670$</field>
    <options>no_full_log</options>
    <description>AD: Permissions changed on object by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1222</id>
    </mitre>
    <group>policy_changed,permissions_changed,</group>
  </rule>

  <!-- ============================================================
       SECTION 4 — Logon / Logoff Anomalies
       No default rule matches 4648 — left under 60103.
       ============================================================ -->

  <!-- Explicit Credential Logon (RunAs / credential harvesting indicator) -->
  <rule id="100322" level="8">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4648$</field>
    <field name="win.eventdata.subjectDomainName" negate="yes" type="pcre2">(?i)^NT SERVICE$|^NT AUTHORITY$|^Window Manager$|^Font Driver Host$</field>
    <field name="win.eventdata.subjectUserName" negate="yes" type="pcre2">\$$</field>
    <options>no_full_log</options>
    <description>AD: Explicit credential logon - $(win.eventdata.subjectUserName) used creds of $(win.eventdata.targetUserName) to $(win.eventdata.targetServerName)</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,lateral_movement,</group>
  </rule>

  <!-- Multiple explicit-credential logons — lateral movement indicator -->
  <rule id="100323" level="13" frequency="5" timeframe="180">
    <if_matched_sid>100322</if_matched_sid>
    <same_field>win.eventdata.subjectUserName</same_field>
    <options>no_full_log</options>
    <description>AD: Multiple explicit-credential logons by $(win.eventdata.subjectUserName) — possible lateral movement</description>
    <mitre>
      <id>T1021</id>
    </mitre>
    <group>lateral_movement,</group>
  </rule>

  <!-- ============================================================
       SECTION 5 — Attack Detection (Kerberoasting, DCSync)

       100331 correlates on 110002 (Kerberoasting base rule in
       local_rules.xml). 110002 was itself silenced (it sat under 60103
       as a sibling of 60106, which matches 4769); it has now been
       re-parented to 60106, so 110002 fires and this correlation works.

       100332 (DCSync via 4662): no default rule matches 4662, so it
       fires correctly under 60103 — left unchanged.
       ============================================================ -->

  <!-- Kerberoasting in Progress: Burst of RC4 TGS requests from same IP -->
  <rule id="100331" level="14" frequency="8" timeframe="120">
    <if_matched_sid>110002</if_matched_sid>
    <same_field>win.eventdata.ipAddress</same_field>
    <options>no_full_log</options>
    <description>AD: Kerberoasting in progress — multiple RC4 TGS requests from same source</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>attack,credential_theft,kerberoasting,</group>
  </rule>

  <!-- DCSync Attack: Replication Rights Used -->
  <rule id="100332" level="15">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4662$</field>
    <field name="win.eventdata.properties" type="pcre2">1131f6aa|1131f6ad|89e95b76</field>
    <field name="win.eventdata.subjectUserName" negate="yes" type="pcre2">\$$|^MSOL_|^AAD_|^ADSync|^Azure AD Sync</field>
    <options>no_full_log</options>
    <description>AD: DCSync attack - replication rights used by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1003.006</id>
    </mitre>
    <group>attack,credential_theft,dcsync,</group>
  </rule>

  <!-- ============================================================
       SECTION 6 — Process Creation (Offensive Tooling)

       Native Windows Security Event 4688 (Process Creation). No default
       rule matches 4688, so these fire correctly under 60103 — unchanged.

       REQUIRES: GPO "Audit Process Creation" = Enabled AND "Include
       command line in process creation events" = Enabled. (If neither
       4688 nor Sysmon EID 1 is being collected, these stay dormant by
       design — verify with logtest using a sample 4688 event.)
       ============================================================ -->

  <!-- Known Offensive Tool Executed -->
  <rule id="100340" level="15">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4688$</field>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)mimikatz|rubeus|bloodhound|sharphound|lazagne|crackmapexec|impacket</field>
    <options>no_full_log</options>
    <description>AD: Known offensive tool executed on $(win.system.computer) — $(win.eventdata.newProcessName)</description>
    <mitre>
      <id>T1003</id>
    </mitre>
    <group>attack,credential_theft,process_creation,</group>
  </rule>

  <!-- net.exe / net1.exe Execution -->
  <rule id="100341" level="10">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4688$</field>
    <field name="win.eventdata.newProcessName">\\net\.exe$|\\net1\.exe$</field>
    <options>no_full_log</options>
    <description>AD: net.exe execution detected on $(win.system.computer) by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>attack,reconnaissance,process_creation,</group>
  </rule>

  <!-- Burst of net.exe from same user — enumeration/recon -->
  <rule id="100342" level="13" frequency="4" timeframe="60">
    <if_matched_sid>100341</if_matched_sid>
    <same_field>win.eventdata.subjectUserName</same_field>
    <options>no_full_log</options>
    <description>AD: Repeated net.exe usage by $(win.eventdata.subjectUserName) — possible enumeration</description>
    <mitre>
      <id>T1087.002</id>
    </mitre>
    <group>attack,reconnaissance,</group>
  </rule>

  <!-- ============================================================
       SECTION 7 — GPO & Policy Changes
       ============================================================ -->

  <!-- Group Policy / Directory Object Modified (default 60229 matches 5136) -->
  <rule id="100350" level="10">
    <if_sid>60229</if_sid>
    <field name="win.system.eventID">^5136$</field>
    <options>no_full_log</options>
    <description>AD: Directory object modified — $(win.eventdata.objectDN) by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1484.001</id>
    </mitre>
    <group>policy_changed,gpo_changed,</group>
  </rule>

  <!-- Audit Policy Changed — 60112 (103-local_rules.xml) is overwritten to
       level=0 so only these specific custom rules generate alerts.
       4907/4912 coverage added here so 60112 can be safely silenced. -->
  <rule id="100351" level="12">
    <if_sid>60112</if_sid>
    <field name="win.system.eventID">^4719$</field>
    <options>no_full_log</options>
    <description>AD: System audit policy changed by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1562.002</id>
    </mitre>
    <group>policy_changed,audit_policy_changed,defense_evasion,</group>
  </rule>

  <rule id="100362" level="8">
    <if_sid>60112</if_sid>
    <field name="win.system.eventID">^4907$</field>
    <options>no_full_log</options>
    <description>AD: Auditing settings on object changed by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1562.002</id>
    </mitre>
    <group>policy_changed,audit_policy_changed,</group>
  </rule>

  <rule id="100363" level="8">
    <if_sid>60112</if_sid>
    <field name="win.system.eventID">^4912$</field>
    <options>no_full_log</options>
    <description>AD: Per-user audit policy changed by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1562.002</id>
    </mitre>
    <group>policy_changed,audit_policy_changed,</group>
  </rule>

  <!-- Security Log Cleared — cover tracks.
       1102 is INFORMATION severity -> default 60117 (under 60100), NOT
       60103/60104. Chained under 60117 so the gate actually opens. -->
  <rule id="100352" level="14">
    <if_sid>60117</if_sid>
    <field name="win.system.eventID">^1102$</field>
    <options>no_full_log</options>
    <description>AD: Security event log cleared on $(win.system.computer) — possible evidence destruction</description>
    <mitre>
      <id>T1070.001</id>
    </mitre>
    <group>defense_evasion,log_cleared,</group>
  </rule>

  <!-- PsExec activity (4688 — no default rule; unchanged) -->
  <rule id="100343" level="13">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4688$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\\PSEXESVC\.exe|\\PsExec(64)?\.exe.*\\\\)</field>
    <options>no_full_log</options>
    <description>AD: PsExec activity on $(win.system.computer) - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1021.002</id>
      <id>T1569.002</id>
    </mitre>
    <group>attack,lateral_movement,process_creation,</group>
  </rule>

  <!-- ============================================================
       SECTION 8 — New High-Value Detections
       ============================================================ -->

  <!-- 4688 originalFileName match — catches renamed offensive tools.
       Requires Windows 10 RS1+ / Server 2016+ for originalFileName in 4688.
       Complements rule 100340 (which matches newProcessName — bypassable by rename). -->
  <rule id="100354" level="15">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4688$</field>
    <field name="win.eventdata.originalFileName" type="pcre2">(?i)mimikatz\.exe|rubeus\.exe|sharphound\.exe|lazagne\.exe|crackmapexec\.exe</field>
    <options>no_full_log</options>
    <description>AD: Known offensive tool PE signature detected (originalFileName) — $(win.eventdata.originalFileName) run by $(win.eventdata.subjectUserName) on $(win.system.computer)</description>
    <mitre>
      <id>T1003</id>
    </mitre>
    <group>attack,credential_theft,process_creation,</group>
  </rule>

  <!-- 4697 — new service installed. No default Wazuh rule covers this EID.
       Machine accounts excluded; SYSTEM service installs are expected noise. -->
  <rule id="100355" level="11">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4697$</field>
    <field name="win.eventdata.subjectUserName" negate="yes" type="pcre2">\$$</field>
    <options>no_full_log</options>
    <description>AD: New service installed — $(win.eventdata.serviceName) by $(win.eventdata.subjectUserName) on $(win.system.computer)</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
    <group>persistence,service_creation,</group>
  </rule>

  <!-- 4776 — NTLM credential validation on DC. No default Wazuh rule covers this EID.
       A burst of 4776 events from same workstation across different users = NTLM spray / PtH indicator. -->
  <rule id="100356" level="6">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4776$</field>
    <field name="win.eventdata.targetUserName" negate="yes" type="pcre2">\$$</field>
    <options>no_full_log</options>
    <description>AD: NTLM credential validation — $(win.eventdata.targetUserName) from $(win.eventdata.workstationName)</description>
    <mitre>
      <id>T1550.002</id>
    </mitre>
    <group>authentication,ntlm,</group>
  </rule>

  <!-- 4698 — scheduled task created by non-system account.
       Parent 60228 is the default L4 rule for 4698 in 0580-win-security_rules.xml.
       SYSTEM / LOCAL SERVICE / NETWORK SERVICE and machine accounts are excluded. -->
  <rule id="100357" level="10">
    <if_sid>60228</if_sid>
    <field name="win.system.eventID">^4698$</field>
    <field name="win.eventdata.subjectUserName" negate="yes" type="pcre2">(?i)^SYSTEM$|^LOCAL SERVICE$|^NETWORK SERVICE$|\$$</field>
    <options>no_full_log</options>
    <description>AD: Scheduled task created by $(win.eventdata.subjectUserName) — $(win.eventdata.taskName) on $(win.system.computer)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>persistence,scheduled_task,</group>
  </rule>

  <!-- 5136 — AdminSDHolder object modification.
       AdminSDHolder tampering grants persistent privileged access via SDProp.
       Parent 60229 is the level=0 overwrite in 103-local_rules.xml; level=0
       parents still route events to children. -->
  <rule id="100359" level="15">
    <if_sid>60229</if_sid>
    <field name="win.system.eventID">^5136$</field>
    <field name="win.eventdata.objectDN" type="pcre2">(?i)AdminSDHolder</field>
    <options>no_full_log</options>
    <description>AD: AdminSDHolder object modified — SDProp persistence by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1484.001</id>
    </mitre>
    <group>attack,persistence,ad_persistence,</group>
  </rule>

  <!-- 4673 SUCCESS — sensitive privilege actually exercised.
       Default rule 60107 covers 4673 FAILURE (if_sid 60104). This rule covers
       SUCCESS events (if_sid 60103) for high-value privileges only.
       SYSTEM and machine accounts excluded as expected callers. -->
  <rule id="100361" level="10">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4673$</field>
    <field name="win.eventdata.privilegeList" type="pcre2">(?i)SeDebugPrivilege|SeTcbPrivilege|SeAssignPrimaryTokenPrivilege</field>
    <field name="win.eventdata.subjectUserName" negate="yes" type="pcre2">\$$|(?i)^SYSTEM$</field>
    <options>no_full_log</options>
    <description>AD: Sensitive privilege exercised — $(win.eventdata.privilegeList) by $(win.eventdata.subjectUserName) on $(win.system.computer)</description>
    <mitre>
      <id>T1134</id>
    </mitre>
    <group>privilege_escalation,</group>
  </rule>

</group>