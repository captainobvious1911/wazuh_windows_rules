<!-- ============================================================
     SECTION 2 - Custom DC detections (no default equivalent)
     ============================================================ -->
<group name="security_event,windows,">

  <!-- DCSync: ignore replication from machine accounts (normal).
       No default matches 4662, so this is a clean child of 60103.
       Pairs with 100332 (which excludes machine accounts). -->
  <rule id="110009" level="0">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4662$</field>
    <field name="win.eventdata.properties" type="pcre2">{1131f6aa-9c07-11d1-f79f-00c04fc2dcd2}|{1131f6ad-9c07-11d1-f79f-00c04fc2dcd2}|{19195a5b-6da0-11d0-afd3-00c04fd930c9}</field>
    <field name="win.eventdata.subjectUserName" type="pcre2">\$$</field>
    <options>no_full_log</options>
    <description>Ignore Directory Service Access from machine account (normal DC replication)</description>
  </rule>

  <!-- Kerberoasting: 4769 RC4 + forwardable/renewable/canonicalize,
       excluding machine accounts and krbtgt. Chains from default
       60106 (which matches 4769 success). Feeds correlation 100331. -->
  <rule id="110002" level="10">
    <if_sid>60106</if_sid>
    <field name="win.system.eventID">^4769$</field>
    <field name="win.eventdata.ticketOptions" type="pcre2">0x40810000</field>
    <field name="win.eventdata.ticketEncryptionType" type="pcre2">0x17</field>
    <field name="win.eventdata.serviceName" negate="yes" type="pcre2">\$$|^krbtgt$</field>
    <options>no_full_log</options>
    <description>Possible Kerberoasting - RC4 TGS request for $(win.eventdata.serviceName) by $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>attack,credential_theft,kerberoasting,</group>
  </rule>

  <!-- Golden Ticket: 4624 logonType 3, Kerberos + null GUID.
       Chains from your 100202 (network logon). The Kerberos filter
       removes the NTLM false positives that plagued the old version. -->
  <rule id="110003" level="12">
    <if_sid>100202</if_sid>
    <field name="win.eventdata.authenticationPackageName" type="pcre2">(?i)^Kerberos$</field>
    <field name="win.eventdata.logonGuid" type="pcre2">^\{0+\-0+\-0+\-0+\-0+\}$</field>
    <options>no_full_log</options>
    <description>Possible Golden Ticket - Kerberos network logon with null GUID on $(win.system.computer) by $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1558.001</id>
    </mitre>
    <group>attack,credential_theft,golden_ticket,</group>
  </rule>

  <!-- Silver Ticket — forged service ticket (4769 success).
       Indicators: RC4 (0x17) or RC4-HMAC-EXP (0x23) encryption on a TGS for a
       non-machine, non-krbtgt SPN, without the Kerberoasting ticket options flag.
       Parent if_sid 60106 covers 4769 (confirmed in 0580:line 78).
       Kerberoasting ticketOptions 0x40810000 is excluded so this does not overlap
       with rule 110002 (Kerberoasting single) or 100331 (Kerberoasting burst). -->
  <rule id="100360" level="13">
    <if_sid>60106</if_sid>
    <field name="win.system.eventID">^4769$</field>
    <field name="win.eventdata.ticketEncryptionType" type="pcre2">0x17|0x23</field>
    <field name="win.eventdata.serviceName" negate="yes" type="pcre2">\$$|^krbtgt$</field>
    <field name="win.eventdata.ticketOptions" negate="yes" type="pcre2">0x40810000</field>
    <options>no_full_log</options>
    <description>AD: Possible Silver Ticket — RC4 service ticket for $(win.eventdata.serviceName) by $(win.eventdata.subjectUserName) on $(win.system.computer)</description>
    <mitre>
      <id>T1558.002</id>
    </mitre>
    <group>attack,credential_theft,silver_ticket,</group>
  </rule>

</group>
