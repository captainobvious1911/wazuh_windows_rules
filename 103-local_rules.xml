<!-- ============================================================
     SECTION 1 - Silence default leaves replaced by custom rules
     overwrite="yes" REPLACES the default rule wholesale, so each block
     below restates the original's parent + eventID match and just sets
     level 0. (The match does NOT have to be byte-identical to the
     original — see 60112, which intentionally also adds 4715 — but
     keeping it aligned avoids silently changing what the gate matches.)
     Children (your 1003xx rules) keep firing because the level-0 parent
     still routes events to them.
     ============================================================ -->
<group name="windows,">

  <!-- 4624 success "Windows Logon Success": replaced by 100200-100208
       (per-logon-type). Silenced to L0 - it still ROUTES to both your
       100200-series AND the 0840 RDP chain (92651->92653/92657), which
       both chain from 60106. So RDP detection via 0840 keeps working. -->
  <rule id="60106" level="0" overwrite="yes">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^528$|^540$|^673$|^4624$|^4769$</field>
    <description>Windows Logon Success (silenced - see 100200-100208 / 0840 RDP)</description>
    <options>no_full_log</options>
    <group>authentication_success,</group>
  </rule>

  <!-- 4625 failure: replaced by 100210-100214. Silenced to L0,
       still routes to those children. -->
  <rule id="60122" level="0" overwrite="yes">
    <if_sid>60105</if_sid>
    <field name="win.system.eventID">^529$|^4625$</field>
    <description>Logon Failure (silenced - see 100210-100214)</description>
    <options>no_full_log</options>
    <group>authentication_failed,</group>
  </rule>

  <!-- 4740 lockout: replaced by 100300 (+correlation 100301) -->
  <rule id="60115" level="0" overwrite="yes">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^644$|^4740$</field>
    <description>Account locked out (silenced - see 100300)</description>
    <options>no_full_log</options>
    <group>account_changed,</group>
  </rule>

  <!-- 4720/4722 created/enabled: replaced by 100304/100306 -->
  <rule id="60109" level="0" overwrite="yes">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^624$|^626$|^4720$|^4722$</field>
    <description>Account created/enabled (silenced - see 100304/100306)</description>
    <options>no_full_log</options>
    <group>account_changed,</group>
  </rule>

  <!-- 4725/4726 disabled/deleted: replaced by 100307/100305 -->
  <rule id="60111" level="0" overwrite="yes">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^630$|^629$|^4725$|^4726$</field>
    <description>Account disabled/deleted (silenced - see 100305/100307)</description>
    <options>no_full_log</options>
    <group>account_changed,</group>
  </rule>

  <!-- Group membership parent 60113: children 60141/42/44/45/51/52
       are what actually fire. We silence those leaves below, but
       60113 itself must stay intact (it's the parent your rules and
       the leaves both chain from). Leave 60113 alone. -->

  <rule id="60141" level="0" overwrite="yes">
